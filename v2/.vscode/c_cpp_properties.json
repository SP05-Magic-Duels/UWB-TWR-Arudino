{
  "version": 4,
  "configurations": [
    {
      "name": "ESP32",
      "compilerPath": "${env:HOME}/.arduino15/packages/esp32/tools/esp-x32/2511/bin/xtensa-esp32-elf-g++",
      "compileCommands": [
        "${workspaceFolder}/build/compile_commands.json"
      ],
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/lib/**",
        "${env:HOME}/.arduino15/packages/esp32/hardware/esp32/**",
        "${env:HOME}/.arduino15/packages/esp32/tools/esp32-libs/**/include/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/lib",
          "${env:HOME}/.arduino15/packages/esp32/hardware/esp32",
          "${env:HOME}/.arduino15/packages/esp32/tools/esp32-libs"
        ]
      },
      "intelliSenseMode": "linux-gcc-x64",
      "cStandard": "c11",
      "cppStandard": "c++17"
    }
  ]
}